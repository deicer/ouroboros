# Ouroboros — Docker VPS Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=              # https://openrouter.ai/keys
TELEGRAM_BOT_TOKEN=              # @BotFather on Telegram
GITHUB_TOKEN=                    # https://github.com/settings/tokens (repo scope)
GITHUB_USER=                     # Your GitHub username
GITHUB_REPO=ouroboros            # Your forked repo name

# ── Optional API Keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=                  # Enables web_search tool
OPENCODE_API_KEY=                # Required for OpenCode Zen provider (including free models)
ANTHROPIC_API_KEY=               # Optional provider key for OpenCode/other tooling

# ── Models ───────────────────────────────────────────────────────────────────
# OUROBOROS_MODEL=anthropic/claude-sonnet-4.6
# OUROBOROS_MODEL_CODE=anthropic/claude-opus-4-6
# OUROBOROS_MODEL_LIGHT=google/gemini-3-pro-preview
# OUROBOROS_REASONING_ENABLED=true
# OUROBOROS_WEBSEARCH_MODEL=gpt-5
# Ordered priority lists (1st = highest priority)
# OUROBOROS_MODEL_PAID_LIST=x-ai/grok-4.1-fast,anthropic/claude-sonnet-4.6,google/gemini-3-pro-preview
# OUROBOROS_MODEL_FREE_LIST=arcee-ai/trinity-large-preview:free,z-ai/glm-4.5-air:free
# OUROBOROS_MODEL_FALLBACK_LIST=anthropic/claude-sonnet-4.6,google/gemini-3-pro-preview,openai/gpt-4.1
# OUROBOROS_AUTO_FREE_SWITCH=true
# OUROBOROS_AUTO_FREE_SWITCH_AT_USD=0.40
# OUROBOROS_OPENCODE_FALLBACK_MODELS=opencode/minimax-m2.5-free,opencode/trinity-large-preview-free

# ── Infrastructure ───────────────────────────────────────────────────────────
# OUROBOROS_MAX_WORKERS=5
# OUROBOROS_MAX_ROUNDS=200
# OUROBOROS_BG_BUDGET_PCT=10
# OUROBOROS_SOFT_TIMEOUT_SEC=600
# OUROBOROS_HARD_TIMEOUT_SEC=1800
# OUROBOROS_DIAG_HEARTBEAT_SEC=30
# OUROBOROS_DIAG_SLOW_CYCLE_SEC=20

# ── Paths (Docker defaults, rarely need changing) ────────────────────────────
# DRIVE_ROOT=/data
# OUROBOROS_REPO_DIR=/app
# OUROBOROS_BRANCH_PREFIX=ouroboros   # Dev branch = prefix, stable = prefix-stable
