# Ouro — Docker VPS Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=              # https://openrouter.ai/keys
TELEGRAM_BOT_TOKEN=              # @BotFather on Telegram
GITHUB_TOKEN=                    # https://github.com/settings/tokens (repo scope)
GITHUB_USER=                     # Your GitHub username
GITHUB_REPO=ouro            # Your forked repo name
ANTHROPIC_API_KEY=               # https://console.anthropic.com/settings/keys — Claude Code CLI for code editing
COMPOSIO_API_KEY=                # https://composio.dev — external app integrations (Gmail, Slack, etc.)
OURO_BRANCH_PREFIX=ouro # Dev branch = prefix, stable branch = prefix-stable

# ── Optional API Keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=                  # Enables web_search tool

# ── Models ───────────────────────────────────────────────────────────────────
# OURO_MODEL=anthropic/claude-sonnet-4.6
# OURO_MODEL_CODE=anthropic/claude-opus-4-6
# OURO_MODEL_LIGHT=google/gemini-3-pro-preview
# OURO_WEBSEARCH_MODEL=gpt-5
# OURO_MODEL_FALLBACK_LIST=anthropic/claude-sonnet-4.6,google/gemini-3-pro-preview,openai/gpt-4.1

# ── Infrastructure ───────────────────────────────────────────────────────────
# OURO_MAX_WORKERS=5
# OURO_MAX_ROUNDS=200
# OURO_BG_BUDGET_PCT=10
# OURO_SOFT_TIMEOUT_SEC=600
# OURO_HARD_TIMEOUT_SEC=1800
# OURO_DIAG_HEARTBEAT_SEC=30
# OURO_DIAG_SLOW_CYCLE_SEC=20

# ── Paths (Docker defaults, rarely need changing) ────────────────────────────
# DRIVE_ROOT=/data
# OURO_REPO_DIR=/app
