# Ouroboros — Docker VPS Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# TELEGRAM_BOT_TOKEN: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# GITHUB_TOKEN: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
# GITHUB_USER: your GitHub username
GITHUB_USER=
# GITHUB_REPO: your forked repo name
GITHUB_REPO=ouroboros

# ── Optional API Keys ────────────────────────────────────────────────────────
# TAVILY_API_KEY: primary backend for web_search (recommended)
TAVILY_API_KEY=
# OPENAI_API_KEY: optional fallback backend for web_search
OPENAI_API_KEY=
# GOOGLE_API_KEY: Google AI Studio key for Mem0 (Gemini embedder/LLM)
GOOGLE_API_KEY=
# OPENCODE_API_KEY: required for OpenCode Zen provider (including free models)
OPENCODE_API_KEY=
# ANTHROPIC_API_KEY: optional provider key for OpenCode/other tooling
ANTHROPIC_API_KEY=

# ── Models ───────────────────────────────────────────────────────────────────
# OUROBOROS_MODEL=anthropic/claude-sonnet-4.6
# OUROBOROS_MODEL_CODE=anthropic/claude-opus-4-6
# OUROBOROS_MODEL_LIGHT=google/gemini-3-pro-preview
# OUROBOROS_REASONING_ENABLED=true
# OUROBOROS_WEBSEARCH_MODEL=gpt-5
# OUROBOROS_TAVILY_BASE_URL=https://api.tavily.com
# OUROBOROS_TAVILY_SEARCH_DEPTH=basic
# OUROBOROS_TAVILY_TOPIC=general
# OUROBOROS_TAVILY_MAX_RESULTS=5
# OUROBOROS_TAVILY_INCLUDE_ANSWER=basic
# OUROBOROS_TAVILY_INCLUDE_RAW_CONTENT=false
# Knowledge backend (Mem0 + Qdrant + Gemini)
# OUROBOROS_KNOWLEDGE_BACKEND=mem0
# OUROBOROS_MEM0_ENABLED=true
# OUROBOROS_MEM0_USER_ID=ouroboros-agent
# OUROBOROS_MEM0_INFER=true
# OUROBOROS_MEM0_MAX_MEMORIES=500
# OUROBOROS_MEM0_QDRANT_URL=http://qdrant:6333
# OUROBOROS_MEM0_QDRANT_COLLECTION=mem0
# OUROBOROS_MEM0_EMBED_MODEL=models/text-embedding-004
# OUROBOROS_MEM0_LLM_MODEL=gemini-2.5-flash
# Ordered priority lists (1st = highest priority)
# OUROBOROS_MODEL_PAID_LIST=x-ai/grok-4.1-fast,anthropic/claude-sonnet-4.6,google/gemini-3-pro-preview
# OUROBOROS_MODEL_FREE_LIST=arcee-ai/trinity-large-preview:free,z-ai/glm-4.5-air:free
# OUROBOROS_MODEL_FALLBACK_LIST=anthropic/claude-sonnet-4.6,google/gemini-3-pro-preview,openai/gpt-4.1
# OUROBOROS_AUTO_FREE_SWITCH=true
# OUROBOROS_AUTO_FREE_SWITCH_AT_USD=0.40
# OUROBOROS_OPENROUTER_BUDGET_MAX_AGE_SEC=1800
# OUROBOROS_OPENCODE_FALLBACK_MODELS=opencode/minimax-m2.5-free,opencode/trinity-large-preview-free
# OUROBOROS_OPENCODE_MAX_RETRIES=1
# OUROBOROS_OPENCODE_ATTEMPT_TIMEOUT_SEC=90
# OUROBOROS_OPENCODE_TOTAL_BUDGET_SEC=260
# OUROBOROS_OPENCODE_AUTO_INSTALL=true
# OUROBOROS_OPENCODE_INSTALL_CMD=curl -fsSL https://opencode.ai/install | bash
# Optional runtime pip packages (installed on restart without image rebuild)
# OUROBOROS_RUNTIME_EXTRA_PIP=faster-whisper,av,scipy,numpy
# OUROBOROS_RUNTIME_EXTRA_PIP_STRICT=false
# OUROBOROS_GIT_LOCK_SAME_PID_STALE_SEC=180
# run_shell safety guards
# OUROBOROS_RUN_SHELL_TIMEOUT_SEC=120
# OUROBOROS_RUN_SHELL_MAX_OUTPUT_BYTES=100000

# ── Infrastructure ───────────────────────────────────────────────────────────
# OUROBOROS_MAX_WORKERS=5
# OUROBOROS_MAX_ROUNDS=200
# OUROBOROS_BG_BUDGET_PCT=10
# OUROBOROS_SOFT_TIMEOUT_SEC=600
# OUROBOROS_HARD_TIMEOUT_SEC=1800
# OUROBOROS_DIAG_HEARTBEAT_SEC=30
# OUROBOROS_DIAG_SLOW_CYCLE_SEC=20
# OUROBOROS_TRACE_WEB_ENABLED=true
# OUROBOROS_TRACE_WEB_HOST=0.0.0.0
# OUROBOROS_TRACE_WEB_PORT=8088

# ── Paths (Docker defaults, rarely need changing) ────────────────────────────
# DRIVE_ROOT=/data
# OUROBOROS_REPO_DIR=/app
# OUROBOROS_BRANCH_PREFIX=ouroboros
# Dev branch = prefix, stable = prefix-stable
